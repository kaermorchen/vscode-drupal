{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Extension",
      "type": "extensionHost",
      "request": "launch",
      "preLaunchTask": "${defaultBuildTask}",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}",
        "--disable-extensions",
      ],
      "outFiles": [
        "${workspaceFolder}/out/extension.js",
      ],
    },
  ]
}
